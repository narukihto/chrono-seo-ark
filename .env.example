# --- ARK SYSTEMS: CHRONO-SEO ENVIRONMENT TEMPLATE ---
# Copy this file to '.env' and fill in the values.

# [Security] GitHub Token for Vault commits
# Requirements: 'repo' or 'contents:write' permissions
GITHUB_TOKEN=your_github_pat_here

# [Access] API Key for Signal Capture (Protocol 15)
# This grants access to the high-frequency trend nodes.
ARK_API_KEY=your_api_key_here

# [Engine] Geometric Calibration
# Default: 12.0 (Dodecagon). Higher = More filtering.
PENTA_V_POLES=12.0

# [Integration] Webhook Observer
# Optional: URL for the webhook_handler.py listener
ARK_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_id/your_token

# [Mode] Deployment Environment
# Options: development, production
ARK_ENV=production
